{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "2.5.0",
  "identifier": "com.nexus.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nexus AI 비서",
        "width": 760,
        "height": 620,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": true,
        "shadow": true,
        "skipTaskbar": false,
        "visible": false,
        "url": "/"
      },
      {
        "label": "character",
        "title": "Nexus",
        "width": 380,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "x": 1500,
        "y": 200,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "url": "/character",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0RTJCMjRCRjFCRjMyQ0MKUldUTU1yL3hTN0xpaEZudzBzY1Npczl1SUdJSk13WTFmUTlJWkhNL1c3TW1HUTYrZjdWczJDZlkK",
      "endpoints": [
        "https://github.com/sansarang/nexus-ai/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "entitlements": "../entitlements.plist",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "음성 인식을 위해 마이크 접근이 필요합니다.",
        "NSSpeechRecognitionUsageDescription": "음성 명령 처리를 위해 음성 인식 권한이 필요합니다."
      }
    }
  }
}
