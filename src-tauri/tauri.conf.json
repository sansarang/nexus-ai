{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "2.6.7",
  "identifier": "com.nexus.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nexus AI 비서",
        "width": 760,
        "height": 620,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": true,
        "shadow": true,
        "skipTaskbar": false,
        "visible": false,
        "url": "/"
      },
      {
        "label": "character",
        "title": "Nexus",
        "width": 380,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "x": 1500,
        "y": 200,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false,
        "url": "/character",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' http://127.0.0.1:17891 https://*.supabase.co https://api.groq.com https://api.tavily.com https://api.perplexity.ai https://fonts.googleapis.com https://fonts.gstatic.com; media-src 'self' blob: https:; frame-src 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "nexus"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0RTJCMjRCRjFCRjMyQ0MKUldUTU1yL3hTN0xpaEZudzBzY1Npczl1SUdJSk13WTFmUTlJWkhNL1c3TW1HUTYrZjdWczJDZlkK",
      "endpoints": [
        "https://github.com/sansarang/nexus-ai-releases/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": {
      "backend-bin/nexus-backend.exe": "nexus-backend.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "macOS": {
      "entitlements": "../entitlements.plist",
      "infoPlist": null
    }
  }
}